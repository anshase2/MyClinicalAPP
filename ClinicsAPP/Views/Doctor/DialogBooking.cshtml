@model ClinicsAPP.DTO.CreateAppointmentRequestDTO;
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var fullName = ViewBag.FullName as string ?? string.Empty;
    var email = ViewBag.Email as string ?? string.Empty;
    var phone = ViewBag.Phone as string ?? string.Empty;
    var currentYear = DateTime.Now.Year;
    var minDate = DateTime.Now.ToString("yyyy-MM-dd");
    var maxDate = new DateTime(currentYear, 12, 31).ToString("yyyy-MM-dd");
}


<link rel="stylesheet" href="~/css/bootstrap.css" />
<link rel="stylesheet" href="~/css/book-appointment.css" />
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}
<div class="modal fade show d-block" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content rounded-4 shadow">
            <div class="modal-header border-0">
                <div>
                    <h5 class="modal-title fw-bold">Book Appointment</h5>
                    <p class="text-muted mb-0">Fill in your details and select a time slot.</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body pt-0">
                <div class="doctor-card d-flex align-items-center justify-content-between mb-4">
                    <div class="d-flex align-items-center gap-3">
                        <img src="~/OIP.webp" class="rounded-circle doctor-img" alt="Doctor" style="width: 50px; height: 50px;" />
                        <div>
                            <div class="fw-semibold">@ViewBag.DoctorName</div>
                            <small class="text-muted">@ViewBag.Specalist</small>
                        </div>
                    </div>
                    <span class="badge bg-primary">@ViewBag.price</span>
                </div>

                <form asp-controller="Appointments" asp-action="DialogBookingPost" asp-route-id="@Model.DoctorId" method="post" id="bookingForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="DoctorId" />
                    @*<input type="hidden" asp-for="PatientId" />*@
                    <input type="hidden" id="PatientId" name="PatientId" value="@Model.PatientId" />
                    @*<input type="hidden" asp-for="AppointmentDate" id="hiddenAppointmentDate" />*@
                    <input type="hidden" name="AppointmentDate" id="hiddenAppointmentDate" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Full Name</label>
                            <input type="text" class="form-control" value="@fullName" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone Number</label>
                            <input name="Phone" type="text" class="form-control" value="@phone" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Email Address</label>
                        <input type="email" class="form-control" value="@email" readonly />
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Select Date</label>
                            <input type="date" id="displayDate" class="form-control" min="@minDate" max="@maxDate" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Select Time</label>
                            <select id="displayTime" class="form-select" required>
                                <option value="">Choose Time...</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill py-2">Confirm Booking</button>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mt-3">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const dateInput = document.getElementById("displayDate");
        const timeSelect = document.getElementById("displayTime");
        const hiddenInput = document.getElementById("hiddenAppointmentDate");
        const form = document.getElementById("bookingForm");

        function updateTimeSlots(selectedDate) {
            if (!selectedDate) return;

            const date = new Date(selectedDate);
            const day = date.getDay(); // 0: Sun, 1: Mon, ..., 4: Thu, 5: Fri, 6: Sat

            // Thursday (4) & Saturday (6) -> 10:00–17:00
            // Other days -> 08:00–17:00
            let startHour = (day === 4 || day === 6) ? 10 : 8;
            let endHour = 17;

            timeSelect.innerHTML = '<option value="">Choose Time...</option>';
            for (let hour = startHour; hour < endHour; hour++) {
                const timeStr = hour.toString().padStart(2, '0') + ':00';
                const option = document.createElement("option");
                option.value = timeStr;
                option.textContent = timeStr;
                timeSelect.appendChild(option);
            }
        }

        dateInput.addEventListener("change", function () {
            updateTimeSlots(this.value);
            syncHiddenInput();
            console.log("PatientId:", document.getElementById("PatientId").value);
    console.log("AppointmentDate:", hiddenInput.value);
        });

        timeSelect.addEventListener("change", syncHiddenInput);

        function syncHiddenInput() {
            if (dateInput.value && timeSelect.value) {
                // Combine Date and Time for ASP.NET Core DateTime binding
                hiddenInput.value = `${dateInput.value}T${timeSelect.value}:00`;
            } else {
                hiddenInput.value = "";
            }
        }

        form.addEventListener("submit", function (e) {
            syncHiddenInput();
            if (!hiddenInput.value) {
                e.preventDefault();
                alert("Please select both date and time.");
            }
        });
    });
</script>
