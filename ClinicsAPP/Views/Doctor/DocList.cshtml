
@using ClinicsAPP.DTO
@model List<DoctorResponseDTO>;
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers;

<link rel="stylesheet" href="~/css/StyleSheetDocList.css" />

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold display-5">Find & Book Your <span class="text-primary-custom">Doctor</span></h1>
        <p class="text-muted">Search from thousands of verified doctors and book appointments instantly.</p>
    </div>

    <div class="card shadow-sm border-0 rounded-4 p-4 mx-auto search-card">
        <div class="card-body">
            <h5 class="card-title mb-4 d-flex align-items-center">
                <i class="bi bi-search me-2"></i> Search Options
            </h5>

            <form action="/Doctor/Search" method="get">
                <div class="row g-3">

                    <!-- Doctor Name -->
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-semibold">Doctor Name</label>
                        <input name="DoctorName" class="form-control bg-light border-0 py-2" value="@(ViewBag.DoctorName ?? "")" placeholder="@(ViewBag.DoctorName ?? "Search by name...")">
                    </div>

                    <!-- Gender -->
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-semibold">Gender</label>
                        <select name="Gender" class="form-select bg-light border-0 py-2">
                            <option value="@(ViewBag.Gender ?? "")">@(ViewBag.Gender ?? "All Gender")</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>

                    <!-- Location -->
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-semibold">Location</label>
                        <select name="Location" class="form-select bg-light border-0 py-2">
                            <option value="@(ViewBag.Location ?? "")">@(ViewBag.Location ?? "All Locations")</option>
                            <option value="Amman">Amman</option>
                            <option value="Irbid">Irbid</option>
                            <option value="Zarqa">Zarqa</option>
                            <option value="Aqaba">Aqaba</option>
                            <option value="Madaba">Madaba</option>
                            <option value="Salt">Salt</option>
                            <option value="Jerash">Jerash</option>
                            <option value="Karak">Karak</option>
                            <option value="Ma'an">Ma'an</option>
                            <option value="Tafilah">Tafilah</option>
                            <option value="Mafraq">Mafraq</option>
                        </select>
                    </div>

                    <!-- Medical Specialty -->
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-semibold">Medical Specialty</label>
                        <select name="Specialty" class="form-select bg-light border-0 py-2">
                            <option value="@(ViewBag.Specialty ?? "")">@(ViewBag.Specialty ?? "All Specialties")</option>
                            <option value="Cardiology">Cardiology (Heart)</option>
                            <option value="Dermatology">Dermatology (Skin)</option>
                            <option value="Pediatrics">Pediatrics (Children)</option>
                            <option value="Neurology">Neurology (Brain & Nerves)</option>
                            <option value="Orthopedics">Orthopedics (Bones)</option>
                            <option value="General Surgery">General Surgery</option>
                            <option value="Internal Medicine">Internal Medicine</option>
                            <option value="Psychiatry">Psychiatry</option>
                            <option value="Gynecology">Gynecology</option>
                            <option value="Ophthalmology">Ophthalmology (Eyes)</option>
                            <option value="ENT">ENT (Ear, Nose & Throat)</option>
                            <option value="Urology">Urology</option>
                            <option value="Radiology">Radiology</option>
                            <option value="Anesthesiology">Anesthesiology</option>
                            <option value="Oncology">Oncology (Cancer)</option>
                            <option value="Endocrinology">Endocrinology (Hormones)</option>
                            <option value="Pulmonology">Pulmonology (Lungs)</option>
                            <option value="Gastroenterology">Gastroenterology (Digestive)</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-semibold">Sort By</label>
                        <select name="SortBy" class="form-select bg-light border-0 py-2">
                            <option value="@(ViewBag.SortBy ?? "")">@(ViewBag.SortBy ?? "Default")</option>

                       
                            <option value="Price">Price</option>
                            <option value="Rating">Rating</option>
                        </select>
                    </div>
                    
                   

                              
                           
                </div>

                @*Action Buttons 
                <div class="d-flex justify-content-end gap-2 mt-4">
                    <button type="reset" class="btn btn-light border px-4 d-flex align-items-center">
                        <i class="bi bi-x-lg me-2"></i> Clear
                    </button> *@
                <div class="d-flex justify-content-end gap-2 mt-4">

                <button type="button" class="btn btn-light border px-4 d-flex align-items-center"
                        onclick="window.location='/Doctorlist'">
                    <i class="bi bi-x-lg me-2"></i> Clear
                </button>
              

                    <button type="submit" class="btn btn-primary-custom px-4 d-flex align-items-center text-white">
                        <i class="bi bi-search me-2"></i> Search
                    </button>
                </div>
               
            </form>
        </div>
    </div>
</div>
<!-- Section 2: Available Doctors -->
<div class="results-section">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h3 class="fw-bold mb-1">Available Doctors</h3>
            <p class="text-muted small mb-0">@Model.Count() doctors found</p>
        </div>
        
    </div>

    <div class="row g-4">
        @foreach (var doctor in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm rounded-4 doctor-card">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center">
                                <img src="@(string.IsNullOrEmpty(doctor.ImageUrl)
                                                 ? "/uploads/default-user.png"
                                                 : doctor.ImageUrl)" alt=@doctor.FullName class="rounded-circle me-3 object-fit-cover" width="60" height="60">
                                <div>
                                    <h6 class="fw-bold mb-0">@doctor.FullName</h6>
                                    <p class="text-muted small mb-1">@doctor.Specalist</p>
                                    <div class="d-flex align-items-center text-warning small">
                                        @{
                                            var rating = (int)Math.Round(doctor.AverageRating);
                                        }
                                        @for (int i = 0; i < 5; i++)
                                        {
                                           
                                           


                                            <i class="bi bi-star-fill @(i < rating ? "" : "text-muted opacity-25")"></i>
                                        }
                                        <span class="ms-2 text-dark fw-bold">@doctor.AverageRating</span>
                                        <span class="ms-1 text-muted">(4)</span>
                                    </div>
                                </div>
                            </div>
                            <div class="text-primary-custom fw-bold">
                                @doctor.Price$
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex align-items-center text-muted small mb-1">
                                <i class="bi bi-geo-alt me-2"></i> @doctor.Location
                            </div>
                            <div class="d-flex align-items-center text-muted small">
                                <i class="bi bi-telephone me-2"></i> @doctor.Phone
                            </div>
                        </div>

                        <p class="text-muted small mb-4 doctor-description">
                            @doctor.Description
                        </p>

                        <a href="~/Appointments/book-appointment/@doctor.DoctorId" class="btn btn-primary-custom w-200 py-2 rounded-3 text-white">
                           Book Appointment
                        </a>
                      @*   <a asp-controller="Appointments"
                           asp-action="DialogBooking"
                           asp-route-id="@doctor.DoctorId"
                           class="btn btn-primary-custom w-200 py-2 rounded-3 text-white">
                            Book Appointment
                        </a>*@
                        <a href="~/DoctorProfile/@doctor.DoctorId"
                           class="btn btn-primary">
                            See More
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

