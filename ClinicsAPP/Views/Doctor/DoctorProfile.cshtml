                                    </span>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

                 @*   <div class="book-area mt-3 border-top pt-3">
                        <a class="btn btn-primary w-100 py-2 fw-bold mb-2 shadow-sm"
                           asp-controller="Appointment"
                           asp-action="Book"
                           asp-route-id="@Model.DoctorId">
                            BOOK APPOINTMENT
                        </a>
                        <div class="hint text-center text-muted small">
                            <i class="fas fa-bolt me-1 text-warning"></i> Fast booking • Confirm in minutes
                        </div>
                    </div>*@
            <div class="book-area mt-5 border-top pt-3 d-flex justify-content-end">

                <div class="text-end">

                 @*   <a class="btn btn-primary btn-sm px-3 py-2 fw-bold shadow-sm"
                       asp-controller="Appointment"
                       asp-action="Book"
                       asp-route-id="@Model.DoctorId">
                        BOOK APPOINTMENT
                    </a>*@
                    <a class="btn btn-primary btn-sm px-3 py-2 fw-bold shadow-sm" href="~/Appointments/book-appointment/@Model.DoctorId" class="btn btn-primary-custom w-200 py-2 rounded-3 text-white">
                        Book Appointment
                    </a>

                    <div class="hint text-muted small mt-1">
                        <i class="fas fa-bolt me-1 text-warning"></i>
                        Fast booking • Confirm in minutes
                    </div>

                </div>

            </div>
                </div>
            </div>

            <!-- RIGHT: Details with Dynamic Tabs -->
            <div class="col-lg-8">
                <div class="profile-details card border-0 shadow-sm p-0 mb-4 overflow-hidden">
   

                    <!-- Tab Navigation -->
                    <div class="tabs-nav bg-light border-bottom d-flex overflow-auto">
                        <button class="tab-btn active" onclick="switchTab(event, 'about-tab')">
                            <i class="fas fa-user-md me-2"></i>About
                        </button>
                        <button class="tab-btn" onclick="switchTab(event, 'location-tab')">
                            <i class="fas fa-map-marked-alt me-2"></i>Location
                        </button>
                        <button class="tab-btn" onclick="switchTab(event, 'appointments-tab')">
                            <i class="fas fa-calendar-check me-2"></i>Appointments
                        </button>
                        <button class="tab-btn" onclick="switchTab(event, 'hours-tab')">
                            <i class="fas fa-clock me-2"></i>Working Hours
                        </button>
                    </div>

                    <div class="tab-content-container p-4">

                        <!-- About Tab Content -->
                        <div id="about-tab" class="tab-pane active">
                            <h3 class="h5 fw-bold mb-3 text-primary">About the Doctor</h3>
                            <p class="text-muted lh-lg">
                                @(Model.Description ?? "This doctor has not provided a detailed description yet.")
                            </p>

                            <div class="row mt-4 g-3">
                                <div class="col-sm-6">
                                    <div class="p-3 bg-light rounded border-start border-primary border-4">
                                        <div class="small text-muted fw-bold">EXPERIENCE</div>
                                        <div class="fw-bold">10+ Years Professional</div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="p-3 bg-light rounded border-start border-success border-4">
                                        <div class="small text-muted fw-bold">CONSULTATION FEE</div>
                                        <div class="fw-bold text-success">$@(Model.Price?.ToString("F0") ?? "0")</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Location Tab Content -->
                        <div id="location-tab" class="tab-pane d-none">
                            <h3 class="h5 fw-bold mb-3 text-primary">Clinic Location</h3>
                            <div class="card border-0 bg-light p-4 text-center">
                                <div class="mb-3">
                                    <i class="fas fa-hospital-user fa-3x text-primary opacity-50"></i>
                                </div>
                                <h4 class="h6 fw-bold">Primary Practice Address</h4>
                                <p class="text-muted mb-0">
                                    <i class="fas fa-map-marker-alt text-danger me-2"></i>
                                    @(Model.Location ?? "Location information not available.")
                                </p>
                                <div class="mt-3">
                                    <button class="btn btn-outline-primary btn-sm rounded-pill px-4">
                                        <i class="fas fa-directions me-2"></i>Get Directions
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Appointments Tab Content -->
                        <div id="appointments-tab" class="tab-pane d-none">
                            <h3 class="h5 fw-bold mb-3 text-primary">Appointment Statistics</h3>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="card border-0 bg-primary text-white p-4 shadow-sm text-center">
                                        <div class="display-4 fw-bold mb-0">
                                            @* Handling dynamic count safely *@
                                            @{
                                                // Using reflection or dynamic check if the property exists,
                                                // or just use 0 if we can't confirm the property name in DTO
                                                // Based on requirements, I'll use Model.ReviewCount as a fallback or 0
                                                // if Model.Appointments doesn't exist.
                                                int apptCount = 0;
                                                try
                                                {
                                                    // This is a placeholder for where @Model.Appointments.Count() would go
                                                    // apptCount = Model.Appointments?.Count() ?? 0;
                                                    apptCount = Model.AppointmentsCount ?? 0; // Example static-ish dynamic value for demo
                                                }
                                                catch { apptCount = 0; }
                                            }
                                            @apptCount
                                        </div>
                                        <div class="text-uppercase small fw-bold opacity-75">Total Appointments</div>
                                        <i class="fas fa-users fa-4x position-absolute end-0 bottom-0 opacity-25 me-3 mb-2"></i>
                                    </div>
                                </div>
                                <div class="col-md-6 mt-3 mt-md-0">
                                    <div class="card border-0 bg-light p-4 h-100 d-flex flex-column justify-content-center">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fas fa-check-circle text-success me-2"></i>
                                            <span>98% Patient Satisfaction</span>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-bolt text-warning me-2"></i>
                                            <span>Avg. 15 min wait time</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Working Hours Tab Content -->
                        <div id="hours-tab" class="tab-pane d-none">
                            <h3 class="h5 fw-bold mb-3 text-primary">Clinic Working Hours</h3>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="card border-0 bg-white shadow-sm p-3 border-top border-primary border-4">
                                        <div class="d-flex align-items-center mb-3">
                                            <div class="bg-primary text-white rounded p-2 me-3">
                                                <i class="fas fa-calendar-day"></i>
                                            </div>
                                            <h4 class="h6 fw-bold mb-0">Regular Days</h4>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="text-muted">Sunday - Thursday</span>
                                            <span class="badge bg-light text-dark border">9:00 AM - 5:00 PM</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card border-0 bg-white shadow-sm p-3 border-top border-danger border-4">
                                        <div class="d-flex align-items-center mb-3">
                                            <div class="bg-danger text-white rounded p-2 me-3">
                                                <i class="fas fa-umbrella-beach"></i>
                                            </div>
                                            <h4 class="h6 fw-bold mb-0">Holidays</h4>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="text-muted">Saturday</span>
                                            <span class="badge bg-light text-dark border">10:00 AM - 1:00 PM</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Feedback & Rating Section -->
                <div class="feedback-section">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="h5 fw-bold mb-0">Patient Reviews</h3>
                        <span class="text-muted small">@feedbacks.Count() total reviews</span>
                    </div>
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["ErrorMessage"]
                </div>
            }
                    <!-- Add Feedback Form -->
                    <div class="card border-0 shadow-sm p-4 mb-4 bg-white border-top border-primary border-4">
                        <h4 class="h6 fw-bold mb-3"><i class="fas fa-pen-nib me-2 text-primary"></i>Write a Review</h4>
                       @* <form asp-controller="Feedback" asp-action="Create" method="post">*@
                <form action="/feedback/create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="DoctorId" value="@Model.DoctorId" />

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted text-uppercase">Your Rating</label>
                                <div class="star-rating-input d-flex flex-row-reverse justify-content-end gap-2 text-warning fs-3">
                                    <input type="radio" name="Rating" value="5" id="star5" class="d-none" required />
                                    <label for="star5" class="far fa-star cursor-pointer" onclick="highlightStars(5)"></label>
                                    <input type="radio" name="Rating" value="4" id="star4" class="d-none" />
                                    <label for="star4" class="far fa-star cursor-pointer" onclick="highlightStars(4)"></label>
                                    <input type="radio" name="Rating" value="3" id="star3" class="d-none" />
                                    <label for="star3" class="far fa-star cursor-pointer" onclick="highlightStars(3)"></label>
                                    <input type="radio" name="Rating" value="2" id="star2" class="d-none" />
                                    <label for="star2" class="far fa-star cursor-pointer" onclick="highlightStars(2)"></label>
                                    <input type="radio" name="Rating" value="1" id="star1" class="d-none" />
                                    <label for="star1" class="far fa-star cursor-pointer" onclick="highlightStars(1)"></label>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted text-uppercase">Your Comment</label>
                                <textarea name="Comment" class="form-control border-0 bg-light p-3" rows="3"
                                          placeholder="How was your visit with Dr. @Model.FullName?" required></textarea>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm">
                                    Submit Review <i class="fas fa-paper-plane ms-2"></i>
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Feedback List -->
                    <div class="feedback-list">
                        @if (feedbacks.Any())
                        {
                            @foreach (var feedback in feedbacks)
                            {
                                <div class="card border-0 shadow-sm p-4 mb-3 feedback-card border-start border-primary border-4">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3"
                                                 style="width: 45px; height: 45px; font-weight: bold;">
                                                P
                                            </div>
                                            <div>
                                                <a asp-controller="Patient" asp-action="Profile" asp-route-id="@feedback.PatientId"
                                                   class="fw-bold text-decoration-none text-dark hover-primary">
                                            @feedback.PatientName
                                        </a>
                                                <div class="text-warning small mt-1">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        <i class="@(i <= feedback.Rating ? "fas" : "far") fa-star"></i>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        <div class="text-muted small bg-light px-2 py-1 rounded">
                                            <i class="far fa-calendar-alt me-1"></i>@feedback.FeedbackDate?.ToString("MMMM dd, yyyy")
                                        </div>
                                    </div>
                                    <p class="mb-0 text-secondary italic">"@feedback.Comment"</p>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5 text-muted bg-white shadow-sm rounded">
                                <i class="fas fa-comments fs-1 mb-3 text-light"></i>
                                <p class="mb-0">No reviews yet. Be the first to share your experience!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cursor-pointer {
        cursor: pointer;
    }

    /* Tabs Styling */
    .tab-btn {
        border: none;
        background: transparent;
        padding: 1rem 1.5rem;
        color: #6c757d;
        font-weight: 600;
        transition: all 0.3s ease;
        border-bottom: 3px solid transparent;
        white-space: nowrap;
    }

        .tab-btn:hover {
            color: #0d6efd;
            background: rgba(13, 110, 253, 0.05);
        }

        .tab-btn.active {
            color: #0d6efd;
            border-bottom-color: #0d6efd;
            background: white;
        }

    .tab-pane {
        animation: fadeIn 0.4s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Interactive Star Rating */
    .star-rating-input label:hover,
    .star-rating-input label:hover ~ label,
    .star-rating-input input:checked ~ label {
        color: #ffc107;
        font-weight: 900;
    }

        .star-rating-input label:hover:before,
        .star-rating-input label:hover ~ label:before,
        .star-rating-input input:checked ~ label:before {
            content: "\f005";
            font-family: "Font Awesome 6 Free";
        }

    .hover-primary:hover {
        color: #0d6efd !important;
    }

    .italic {
        font-style: italic;
    }

    .profile-card {
        position: sticky;
        top: 20px;
        width: 500px;
      
        padding: 5px;
       
    }

    @@media (max-width: 991.98px) {
        .profile-card {
            position: static;
        }
    }
</style>

<script>
    function switchTab(event, tabId) {
        // Remove active class from all buttons
        const buttons = document.querySelectorAll('.tab-btn');
        buttons.forEach(btn => btn.classList.remove('active'));

        // Add active class to clicked button
        event.currentTarget.classList.add('active');

        // Hide all tab panes
        const panes = document.querySelectorAll('.tab-pane');
        panes.forEach(pane => {
            pane.classList.add('d-none');
            pane.classList.remove('active');
        });

        // Show the selected tab pane
        const selectedPane = document.getElementById(tabId);
        selectedPane.classList.remove('d-none');
        setTimeout(() => {
            selectedPane.classList.add('active');
        }, 10);
    }

    function highlightStars(rating) {
        // This is mainly handled by CSS, but can be used for additional JS logic
        console.log("Selected rating: " + rating);
    }
</script>
