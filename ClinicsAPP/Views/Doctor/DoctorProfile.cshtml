            <div class="profile-page">

                <div class="profile-grid">

                    <!-- LEFT: Doctor Card -->
                 
                    <div class="profile-card">

                        <div class="profile-head">

                            <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl)
                                                             ? Url.Content("~/OIP.webp")
                                                             : Model.ImageUrl)"
                                 class="doctor-img"
                                 alt="Doctor @Model.FullName" />

                            <div class="profile-meta">

                                <h2>@Model.FullName</h2>

                                <div class="specialty">
                                    @Model.Specalist
                                </div>

                                <div class="location">
                                    <i class="fas fa-map-marker-alt"></i>
                                    @Model.Location
                                </div>

                                <div class="badges">

                                    <span class="badge">
                                        ⭐ @(Model.AverageRating.ToString("F1") ?? "0.0")
                                    </span>

                                    <span class="badge">
