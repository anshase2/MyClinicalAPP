@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using ClinicsAPP.Models;
@using ClinicsAPP.Services;
@using System.Security.Claims
@inject DoctorService _doctorService

@{
    string image = "/uploads/default-user.png";

    if (User.IsInRole("Doctor"))
    {
        var userIdString = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (Guid.TryParse(userIdString, out var userId))
        {
            var doctor = await _doctorService.GetDoctorByUserId(userId);

            if (doctor != null && !string.IsNullOrEmpty(doctor.ImageUrl))
            {
                image = doctor.ImageUrl ?? "/uploads/default-user.png";
            }
        }
    }
}

