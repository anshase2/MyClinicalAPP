<link rel="stylesheet" href="~/css/bootstrap.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
@{Layout = "_Layout";}
@model List<ClinicsAPP.DTO.AppointmentResponseDTO>

@{
    ViewData["Title"] = "My Appointments";
}

<div class="container mt-4">
    <h1 class="mb-4">My Appointments</h1>
    @if (TempData["SuccessMessage"] is string msg)
    {
        <div id="toast" class="alert alert-success">
            @msg
        </div>
    }
    
    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            No appointments found.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var appointment in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">
                                @if (User.IsInRole("Patient"))
                                {
                                    <span>Dr. @appointment.DoctorName</span>
                                }
                                else if (User.IsInRole("Doctor"))
                                {
                                    @* The provided DTO (AppointmentResponseDTO) does not include PatientName. *@
                                    @* For a complete implementation, the DTO should be extended to include PatientName, or it should be fetched separately. *@
                                    <span>Patient: @(appointment.PatientName)</span> @* Using PatientId as a placeholder for now. *@
                                }
                            </h5>
                            <p class="card-text">
                                <strong>Date:</strong> @appointment.AppointmentDate.ToString("dd/MM/yyyy")<br />
                                <strong>Time:</strong> @appointment.AppointmentDate.ToString("hh:mm tt")
                            </p>
                            <p class="card-text">
                                <strong>Status:</strong>
                                @{
                                    string badgeClass = "";
                                    string statusText = "Unknown";

                                    // TODO: The AppointmentResponseDTO needs a 'Status' property (e.g., public string Status { get; set; };)
                                    // For now, using a placeholder status. Replace '"Pending"' with 'appointment.Status' once available.
                                    var currentStatus = appointment.Status; // Example: "Pending", "Accepted", "Rejected", "Cancelled"

                                    switch (currentStatus)
                                    {
                                        case "Pending":
                                            badgeClass = "bg-warning";
                                            statusText = "Pending";
                                            break;
                                        case "Accepted":
                                            badgeClass = "bg-success";
                                            statusText = "Accepted";
                                            break;
                                        case "Rejected":
                                            badgeClass = "bg-danger";
                                            statusText = "Rejected";
                                            break;
                                      
                                        default:
                                            badgeClass = "bg-info"; // Default for unknown status
                                            statusText = "Unknown";
                                            break;
                                    }
                                }
                                <span class="badge @badgeClass">@statusText</span>
                            </p>

                            @{
                                var isAppointmentInFuture = appointment.AppointmentDate > DateTime.Now;
                                var isMoreThan24HoursAway = (appointment.AppointmentDate - DateTime.Now).TotalHours > 24;
                                // TODO: Replace 'currentStatus' with actual appointment.Status once available.
                                var isPending = currentStatus == "Pending";
                            }

                            <div class="mt-3">
                                @if (User.IsInRole("Patient"))
                                {
                                    @if (isAppointmentInFuture && isMoreThan24HoursAway)
                                    {
                                        <button type="button" class="btn btn-danger btn-sm">Cancel</button>
                                    }
                                }
                                else if (User.IsInRole("Doctor"))
                                {
                                    @if (isAppointmentInFuture)
                                    {
                                       @* <button type="button" class="btn btn-success btn-sm me-2">Accept</button>
                                        <button type="button" class="btn btn-danger btn-sm">Reject</button>*@
                                        <a class="btn btn-danger btn-sm" href="/Appointments/reject-appointment/@appointment.Id"> Reject</a>
                                      @*  <form asp-controller="Appointments"
                                              asp-action="RejectAppointment"
                                              asp-route-id="@appointment.Id"
                                              method="post"
                                              style="display:inline">

                                            <button type="submit" class="btn btn-danger btn-sm">
                                                Reject
                                            </button>

                                        </form>*@
                                    }
                                }
                               

                            </div>
                        </div>
                    </div>
                </div>
            }
           

        </div>
    }
</div>

@section Scripts {
    <script>
        // Optional: Add JavaScript for button actions (e.g., AJAX calls to update appointment status)
        // Example: Event listeners for the Accept, Reject, and Cancel buttons.
        // You would typically use JavaScript to send an AJAX request to a controller action
        // to update the appointment status in the database and then refresh the UI.
    </script>
}

