@using ClinicsAPP.DTO;
@model LoginDTO
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" asp-href-include="~/css/login.css" />

<div class="full-page-container">
    <!-- Section 1: Sign In (Full Screen) -->
    <section class="vh-section login-section d-flex align-items-center justify-content-center">
        <div class="container">
            <div class="login-wrapper mx-auto text-center">
                <div class="mb-4">
                    <img src="~/Homeicon.jpg" alt="DocTime" height="40" class="mb-3">
                    <h2 class="fw-bold text-dark-blue">Welcome Back</h2>
                    <p class="text-muted">Sign in to your account to continue</p>
                </div>

                <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 text-start login-card">
                    <h3 class="fw-bold mb-1">Sign In</h3>
                    <p class="text-muted small mb-4">Enter your credentials to access your account</p>

                    <form asp-controller="Account"
                          asp-action="Login"
                          asp-route-ReturnUrl="@Context.Request.Query["ReturnUrl"]"
                          method="post">

                        <!-- Email -->
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Email</label>

                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <i class="bi bi-envelope text-muted"></i>
                                </span>

                                <input asp-for="Email"
                                       type="email"
                                       class="form-control border-start-0 ps-0"
                                       placeholder="john@example.com" />
                            </div>

                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Password -->
                        <div class="mb-4">
                            <label class="form-label small fw-semibold">Password</label>

                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <i class="bi bi-lock text-muted"></i>
                                </span>

                                <input asp-for="Password"
                                       type="password"
                                       class="form-control border-start-0 ps-0"
                                       placeholder="Enter your password" />
                            </div>

                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <button type="submit"
                                class="btn btn-primary-custom w-100 py-2 fw-bold mb-3">
                            Sign In
                        </button>

                        <div class="text-center">

                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="text-red">
                                    <ul>
                                        @foreach (var value in ViewData.ModelState.Values)
                                        {
                                            @foreach (var error in value.Errors)
                                            {
                                                <li>@error.ErrorMessage</li>
                                            }
                                        }
                                    </ul>
                                </div>
                            }

                            <span class="text-muted small">
                                Don't have an account?
                                <a href="/Account/Register"
                                   class="text-primary-custom text-decoration-none fw-semibold">
                                    Register
                                </a>
                            </span>
                        </div>

                    </form>
                </div>

                <div class="mt-4 text-muted small">
                    Made with <span class="text-danger">❤</span> by DocTime
                </div>
            </div>
        </div>

        <div class="scroll-indicator">
            <div class="mouse-icon"></div>
        </div>
    </section>
</div>